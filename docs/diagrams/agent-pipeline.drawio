        </mxCell>
        <mxCell id="synth" value="&lt;b&gt;synthesis.py — GPT-4o (Senior UX Lead role)&lt;/b&gt;&lt;br/&gt;Receives: 4 agent JSON reports + weighted score calculation&lt;br/&gt;Produces: topIssues[3] + 2–3 sentence executive summary + grade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;shadow=1;" vertex="1" parent="1">

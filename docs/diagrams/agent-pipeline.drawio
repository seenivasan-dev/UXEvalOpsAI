          <mxGeometry x="262" y="198" width="180" height="16" as="geometry" />
        </mxCell>
        <mxCell id="coord" value="&lt;b&gt;coordinator.py&lt;/b&gt;&lt;br/&gt;asyncio.gather(return_exceptions=True)&lt;br/&gt;Fan-out to 4 specialist agents concurrently" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD966;strokeColor=#d79b00;fontSize=12;shadow=1;" vertex="1" parent="1">

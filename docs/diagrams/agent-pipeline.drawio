        <mxCell id="z-synth-lbl" value="PATTERN: Orchestrator-Synthesis — all specialist outputs funnelled into one holistic narrative" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;fontStyle=3;fontSize=10;fontColor=#b85450;" vertex="1" parent="1">

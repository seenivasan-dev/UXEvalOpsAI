        <mxCell id="a-ct" value="&lt;b&gt;Copy &amp; Tone Agent&lt;/b&gt;&lt;br/&gt;Microcopy · CTAs&lt;br/&gt;Error messages · tone&lt;br/&gt;&lt;br/&gt;score 0–100 → JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;shadow=1;" vertex="1" parent="1">

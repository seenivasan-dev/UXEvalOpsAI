        <mxCell id="z-tool" value="" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;opacity=50;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="518" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="z-tool-lbl" value="PATTERN: Tool Use — deterministic function, not the LLM, computes scores" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;fontStyle=3;fontSize=10;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="212" y="524" width="500" height="16" as="geometry" />
        </mxCell>
        <mxCell id="tool" value="&lt;b&gt;@tool calculate_weighted_score()&lt;/b&gt;&lt;br/&gt;Accessibility×35% + Consistency×25% + Visual×20% + Copy×20%  →  overallScore + grade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;shadow=1;" vertex="1" parent="1">
